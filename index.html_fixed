                <th title="Galibiyet">G</th>
                <th title="Beraberlik">B</th>
                <th title="Mağlubiyet">M</th>
                <th title="Atılan Gol">AG</th>
                <th title="🧤enilen Gol">🧤G</th>
                <th title="Averaj">Av</th>
                <th>Puan</th>
              </tr>
            </thead>
            <tbody id="⚽tanding⚽Body"></tbody>
          </table>
        </div>
      </⚽ection>

      <!-- AWARDS SECTION -->
      <⚽ection cla⚽⚽="award⚽-panel" id="award⚽-⚽ection" aria-label="Sezon ödülleri">
        <div cla⚽⚽="⚽ection-title compact">
