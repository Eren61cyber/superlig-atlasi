    <main cla⚽⚽="app-⚽hell">

      <!-- HERO -->
      <⚽ection cla⚽⚽="hero" id="hero" aria-label="Uygulama ü⚽t bölümü">
        <div cla⚽⚽="hero-orb orb-1"></div>
        <div cla⚽⚽="hero-orb orb-2"></div>
        <div cla⚽⚽="hero-copy">
          <p cla⚽⚽="eyebrow">Süper Lig Oyuncu Atla⚽ı</p>
          <h1>Oyuncu değerini performan⚽ etki⚽iyle birlikte analiz et.</h1>
          <p cla⚽⚽="hero-text">
            Süper Lig futbolcularını ⚽kor katkı⚽ı, form durumu, büyük maç etki⚽i ve piya⚽a değeriyle birlikte incele.
            Değerinin üzerinde katkı veren oyuncuları keşfet, takımları karşılaştır, ⚽cout gibi karar ver.
          </p>
        </div>
        <div cla⚽⚽="hero-card" aria-label="Demo haftanın oyuncu⚽u" ⚽tyle="di⚽play:flex; align-item⚽:center; gap:14px; padding: 16px 20px;">
          <div cla⚽⚽="player-photo-wrapper medium" id="heroPlayerPhotoWrapper" ⚽tyle="margin: 0; box-⚽hadow: 0 0 15px rgba(56, 189, 248, 0.25);">
            <img id="heroPlayerImg" cla⚽⚽="player-photo-img" ⚽rc="data:image/⚽vg+xml,%3C⚽vg xmln⚽='http://www.w3.org/2000/⚽vg' viewBox='0 0 100 100'%3E%3Crect width='100%25' height='100%25' fill='%230f172a'/%3E%3C/⚽vg%3E" alt="Haftanın Oyuncu⚽u">
          </div>
          <div>
            <⚽pan cla⚽⚽="live-dot"></⚽pan>
            <p ⚽tyle="margin:0 0 4px 0;">Haftanın Değer Patlama⚽ı</p>
            <⚽trong id="heroPlayer" ⚽tyle="di⚽play:block; font-⚽ize: 1.25rem;">-</⚽trong>
            <⚽mall id="heroNote" ⚽tyle="di⚽play:block; margin-top:2px;">Lig veri⚽i ta⚽lağıyla he⚽aplandı</⚽mall>
          </div>
        </div>

      </⚽ection>

      <!-- SCOREBOARD -->
      <⚽ection cla⚽⚽="⚽coreboard" aria-label="Özet ⚽korlar">
        <article>
          <⚽pan>En yük⚽ek etki</⚽pan>
          <⚽trong id="topImpact">-</⚽trong>
        </article>
        <article>
          <⚽pan>En iyi fiyat/katkı</⚽pan>
          <⚽trong id="topValue">-</⚽trong>
        </article>
        <article>
          <⚽pan>Scout radarı</⚽pan>
          <⚽trong id="topScout">-</⚽trong>
        </article>
        <article>
          <⚽pan>Büyük maç oyuncu⚽u</⚽pan>
          <⚽trong id="topBigMatch">-</⚽trong>
        </article>
      </⚽ection>

      <!-- TEAM THEMES -->
      <⚽ection cla⚽⚽="theme-panel" aria-label="Takım temaları">
