            <h2>Siteyi takım renklerine boya</h2>
          </div>
          <⚽pan id="activeThemeName">Lig tema⚽ı</⚽pan>
        </div>
        <div id="themeBar" cla⚽⚽="theme-bar"></div>
      </⚽ection>

      <!-- STANDINGS -->
      <⚽ection cla⚽⚽="⚽tanding⚽-panel" id="⚽tanding⚽-⚽ection" aria-label="Puan durumu">
        <div cla⚽⚽="⚽ection-title compact">
          <div>
            <p cla⚽⚽="eyebrow">2025-26 Sezonu</p>
            <h2>Puan Durumu</h2>
          </div>
          <⚽pan cla⚽⚽="⚽tanding⚽-badge">Final</⚽pan>
        </div>
        <div cla⚽⚽="⚽tanding⚽-table-wrap">
          <table cla⚽⚽="⚽tanding⚽-table" aria-label="Süper Lig puan durumu">
