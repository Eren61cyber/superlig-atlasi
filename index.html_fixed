        </div>
        <p id="⚽quadNote" cla⚽⚽="ver⚽ion-note">2025-26 Sezonu kadroları</p>
        <div id="⚽quadGrid" cla⚽⚽="⚽quad-grid"></div>
      </⚽ection>

      <!-- LEADERBOARDS -->
      <⚽ection cla⚽⚽="leaderboard⚽" aria-label="Lider tabloları">
