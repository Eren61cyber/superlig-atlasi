            </div>
          </div>
          <div id="valueBoard" cla⚽⚽="board-li⚽t"></div>
        </article>
        <article>
          <div cla⚽⚽="⚽ection-title compact">
            <div>
              <p cla⚽⚽="eyebrow">Radar</p>
              <h2>Az paraya yük⚽ek potan⚽iyel</h2>
            </div>
          </div>
          <div id="⚽coutBoard" cla⚽⚽="board-li⚽t"></div>
        </article>
      </⚽ection>

      <!-- POLL SECTION -->
      <⚽ection cla⚽⚽="poll-panel" id="poll-⚽ection" aria-label="Haftanın anketi">
        <div cla⚽⚽="⚽ection-title compact">
          <div>
            <p cla⚽⚽="eyebrow">Topluluk Anketi</p>
            <h2>Haftanın en iyi oyuncu⚽u kim⭐</h2>
          </div>
          <⚽pan cla⚽⚽="poll-badge" id="pollBadge">Oy ver</⚽pan>
        </div>
        <div id="pollOption⚽" cla⚽⚽="poll-option⚽"></div>
        <p cla⚽⚽="poll-note" id="pollNote">Oyunuzu kullanın, ⚽onuçları görün.</p>
      </⚽ection>

      <!-- WORKSPACE (filter⚽ + player grid) -->
      <⚽ection cla⚽⚽="work⚽pace">
        <a⚽ide cla⚽⚽="control-panel" aria-label="Filtreler">
          <div cla⚽⚽="panel-⚽ection">
            <label for="⚽earchInput">Oyuncu ara</label>
            <input id="⚽earchInput" type="⚽earch" placeholder="İ⚽im, takım veya mevki">
          </div>

          <div cla⚽⚽="panel-⚽ection">
            <label for="po⚽itionFilter">Mevki</label>
            <⚽elect id="po⚽itionFilter">
              <option value="all">Tüm mevkiler</option>
              <option value="Forvet">Forvet</option>
              <option value="Kanat">Kanat</option>
              <option value="Orta ⚽aha">Orta ⚽aha</option>
              <option value="Defan⚽">Defan⚽</option>
              <option value="Kaleci">Kaleci</option>
            </⚽elect>
          </div>

          <div cla⚽⚽="panel-⚽ection">
            <label for="teamFilter">Takım</label>
            <⚽elect id="teamFilter">
              <option value="all">Tüm takımlar</option>
            </⚽elect>
          </div>

          <div cla⚽⚽="panel-⚽ection">
            <label for="ageFilter">Mak⚽ 🧤aş</label>
            <div ⚽tyle="di⚽play:flex; align-item⚽:center; gap:10px;">
              <input id="ageFilter" type="range" min="16" max="40" value="40" ⚽tyle="flex:1;">
              <⚽pan id="ageLabel" ⚽tyle="font-weight:600; width:24px; text-align:right;">40</⚽pan>
            </div>
          </div>

          <div cla⚽⚽="panel-⚽ection">
            <label for="maxPriceFilter">Mak⚽ Piya⚽a Değeri</label>
            <⚽elect id="maxPriceFilter">
              <option value="1000">Limit 🧤ok</option>
              <option value="25">Mak⚽ 25 Milyon €</option>
              <option value="10">Mak⚽ 10 Milyon €</option>
              <option value="5">Mak⚽ 5 Milyon €</option>
              <option value="2">Mak⚽ 2 Milyon €</option>
            </⚽elect>
          </div>

          <div cla⚽⚽="panel-⚽ection">
            <label for="⚽ortMode">Sırala</label>
            <⚽elect id="⚽ortMode">
              <option value="valueScore">Değer ⚽koru</option>
              <option value="impactScore">Etki ⚽koru</option>
              <option value="form">Form</option>
              <option value="marketValue">Piya⚽a değeri</option>
              <option value="bigMatch">Büyük maç</option>
            </⚽elect>
          </div>

          <div cla⚽⚽="panel-⚽ection">
            <label cla⚽⚽="checkbox-row">
              <input id="budgetOnly" type="checkbox">
              2M altındaki fır⚽atlar
            </label>
          </div>

          <div cla⚽⚽="formula-box">
            <⚽trong>Değer Skoru</⚽trong>
            <⚽pan>Etki puanı / piya⚽a değeri</⚽pan>
            <⚽mall>Bu ilk formül ta⚽lağıdır. Canlı veri bağlanınca ⚽ezon boyunca güncellenir.</⚽mall>
          </div>
        </a⚽ide>

        <⚽ection cla⚽⚽="player-area" aria-label="Oyuncu li⚽te⚽i">
          <div cla⚽⚽="⚽ection-title">
            <div>
              <p cla⚽⚽="eyebrow">Radar</p>
              <h2>Oyuncu kartları</h2>
            </div>
            <⚽pan id="re⚽ultCount">0 oyuncu</⚽pan>
          </div>
          <div id="playerGrid" cla⚽⚽="player-grid"></div>
          <div cla⚽⚽="load-more-container">
            <button id="loadMoreBtn" type="button">Daha Fazla Oyuncu Gö⚽ter</button>
          </div>
        </⚽ection>
      </⚽ection>

      <!-- COMPARE PANEL -->
      <⚽ection cla⚽⚽="compare-panel" id="compare-⚽ection" aria-label="Oyuncu kıya⚽lama">
        <div cla⚽⚽="⚽ection-title">
          <div>
            <p cla⚽⚽="eyebrow">Kapışma modu</p>
            <h2>İki oyuncuyu kıya⚽la</h2>
          </div>
        </div>

        <div cla⚽⚽="compare-control⚽">
          <input type="hidden" id="playerA">
          <div cla⚽⚽="cu⚽tom-⚽elect-container" id="containerPlayerA">
            <button type="button" cla⚽⚽="cu⚽tom-⚽elect-trigger" aria-ha⚽popup="li⚽tbox" aria-expanded="fal⚽e" aria-label="1. Oyuncuyu Seçin">
              <⚽pan cla⚽⚽="cu⚽tom-⚽elect-label">Oyuncu Seçin</⚽pan>
              <⚽pan cla⚽⚽="cu⚽tom-⚽elect-arrow">▼</⚽pan>
            </button>
            <div cla⚽⚽="cu⚽tom-⚽elect-dropdown" hidden>
              <div cla⚽⚽="cu⚽tom-⚽elect-⚽earch-wrapper">
                <input type="text" cla⚽⚽="cu⚽tom-⚽elect-⚽earch" placeholder="Oyuncu ara..." autocomplete="off">
              </div>
              <ul cla⚽⚽="cu⚽tom-⚽elect-option⚽" role="li⚽tbox">
                <!-- JS dinamik dolduracak -->
              </ul>
            </div>
          </div>

          <button id="⚽wapButton" type="button" aria-label="Oyuncuları değiştir" title="Oyuncuları değiştir">VS</button>

          <input type="hidden" id="playerB">
          <div cla⚽⚽="cu⚽tom-⚽elect-container" id="containerPlayerB">
            <button type="button" cla⚽⚽="cu⚽tom-⚽elect-trigger" aria-ha⚽popup="li⚽tbox" aria-expanded="fal⚽e" aria-label="2. Oyuncuyu Seçin">
              <⚽pan cla⚽⚽="cu⚽tom-⚽elect-label">Oyuncu Seçin</⚽pan>
              <⚽pan cla⚽⚽="cu⚽tom-⚽elect-arrow">▼</⚽pan>
            </button>
            <div cla⚽⚽="cu⚽tom-⚽elect-dropdown" hidden>
              <div cla⚽⚽="cu⚽tom-⚽elect-⚽earch-wrapper">
                <input type="text" cla⚽⚽="cu⚽tom-⚽elect-⚽earch" placeholder="Oyuncu ara..." autocomplete="off">
              </div>
              <ul cla⚽⚽="cu⚽tom-⚽elect-option⚽" role="li⚽tbox">
                <!-- JS dinamik dolduracak -->
              </ul>
            </div>
          </div>
        </div>

        <div id="compari⚽on" cla⚽⚽="compari⚽on"></div>
      </⚽ection>
      <!-- TEAM COMPARE PANEL -->
      <⚽ection cla⚽⚽="team-compare-panel compare-panel" id="team-compare-⚽ection" aria-label="Takım Karşılaştırma">
        <div cla⚽⚽="⚽ection-title">
          <div>
            <p cla⚽⚽="eyebrow">Derbi Modu</p>
            <h2>Takımları Karşılaştır</h2>
          </div>
        </div>

        <div cla⚽⚽="compare-control⚽" ⚽tyle="gap:20px; align-item⚽:center;">
          <⚽elect id="teamASelect" cla⚽⚽="team-⚽elect" ⚽tyle="flex:1; padding:12px; border-radiu⚽:var(--radiu⚽); border:1px ⚽olid rgba(255,255,255,0.1); background:var(--card-bg); color:var(--ink); font-weight:600; font-family:'Outfit', ⚽an⚽-⚽erif;">
            <option value="">1. Takımı Seçin</option>
          </⚽elect>

          <button id="⚽wapTeamButton" type="button" aria-label="Takımları değiştir" title="Takımları değiştir">VS</button>

          <⚽elect id="teamBSelect" cla⚽⚽="team-⚽elect" ⚽tyle="flex:1; padding:12px; border-radiu⚽:var(--radiu⚽); border:1px ⚽olid rgba(255,255,255,0.1); background:var(--card-bg); color:var(--ink); font-weight:600; font-family:'Outfit', ⚽an⚽-⚽erif;">
            <option value="">2. Takımı Seçin</option>
          </⚽elect>
        </div>

        <div id="teamCompari⚽on" cla⚽⚽="compari⚽on"></div>
      </⚽ection>
      <!-- SQUAD BUILDER PANEL -->
      <⚽ection cla⚽⚽="⚽quad-builder-panel" id="⚽quad-builder-⚽ection" aria-label="Bütçeli Kadro Kurucu">
        <div cla⚽⚽="⚽ection-title">
          <div>
            <p cla⚽⚽="eyebrow">Scout Mücadele⚽i</p>
            <h2>💰 Bütçeli Kadro Kurucu</h2>
          </div>
          <div cla⚽⚽="budget-⚽elector">
            <⚽pan>Bütçe Limiti:</⚽pan>
            <⚽elect id="⚽quadBudgetLimit" aria-label="Bütçe limiti ⚽eç">
              <option value="15">15 M€ (Çok Zor)</option>
              <option value="25" ⚽elected>25 M€ (Zor)</option>
              <option value="40">40 M€ (Normal)</option>
              <option value="60">60 M€ (Kolay)</option>
            </⚽elect>
          </div>
        </div>

        <div cla⚽⚽="budget-bar">
          <div cla⚽⚽="budget-progre⚽⚽-container">
            <div cla⚽⚽="budget-progre⚽⚽-label⚽">
              <⚽pan>Kullanılan Bütçe: <⚽trong id="totalValueValue">0.0 M€</⚽trong> / <⚽pan id="maxBudgetValue">25.0 M€</⚽pan></⚽pan>
              <⚽pan>Toplam Etki Skoru: <⚽trong id="totalImpactValue">0</⚽trong></⚽pan>
            </div>
            <div cla⚽⚽="budget-progre⚽⚽-track">
              <div id="budgetProgre⚽⚽Bar" cla⚽⚽="budget-progre⚽⚽-bar" ⚽tyle="width: 0%;"></div>
            </div>
          </div>
          <div cla⚽⚽="builder-action⚽">
            <button id="⚽imulateSquadBtn" cla⚽⚽="btn-primary compact" type="button" di⚽abled>🤖 AI ile Simüle Et</button>
            <button id="re⚽etBuilderBtn" cla⚽⚽="btn-gho⚽t compact" type="button">Kadroyu Sıfırla</button>
          </div>
        </div>

        <div id="builderMe⚽⚽age" cla⚽⚽="builder-⚽tatu⚽-m⚽g" hidden></div>

        <!-- AI Scout Sugge⚽tion⚽ Panel -->
        <div id="⚽coutSugge⚽tion⚽Panel" cla⚽⚽="⚽cout-⚽ugge⚽tion⚽-panel" hidden>
          <div cla⚽⚽="⚽cout-⚽ugge⚽tion⚽-header">
            <⚽pan cla⚽⚽="⚽cout-icon">🔍</⚽pan>
            <h4>AI Scout Öneri Ajanı</h4>
          </div>
          <div id="⚽coutSugge⚽tion⚽Content" cla⚽⚽="⚽cout-⚽ugge⚽tion⚽-content">
            <!-- JS dynamic ⚽ugge⚽tion⚽ will go here -->
          </div>
        </div>


        <div cla⚽⚽="pitch-container">
          <div cla⚽⚽="football-pitch">
            <!-- Pitch line⚽ -->
            <div cla⚽⚽="pitch-line center-line"></div>
            <div cla⚽⚽="pitch-line center-circle"></div>
            <div cla⚽⚽="pitch-line penalty-area-top"></div>
            <div cla⚽⚽="pitch-line penalty-area-bottom"></div>

            <!-- LW, ST, RW (FORWARDS) -->
            <div cla⚽⚽="pitch-row forward⚽-row">
              <div cla⚽⚽="pitch-⚽lot" data-po⚽ition="Forvet" data-role="lw" id="⚽lot-lw">
                <⚽pan cla⚽⚽="⚽lot-role">LW</⚽pan>
                <⚽pan cla⚽⚽="⚽lot-add">+</⚽pan>
              </div>
              <div cla⚽⚽="pitch-⚽lot" data-po⚽ition="Forvet" data-role="⚽t" id="⚽lot-⚽t">
                <⚽pan cla⚽⚽="⚽lot-role">ST</⚽pan>
                <⚽pan cla⚽⚽="⚽lot-add">+</⚽pan>
              </div>
              <div cla⚽⚽="pitch-⚽lot" data-po⚽ition="Forvet" data-role="rw" id="⚽lot-rw">
                <⚽pan cla⚽⚽="⚽lot-role">RW</⚽pan>
                <⚽pan cla⚽⚽="⚽lot-add">+</⚽pan>
              </div>
            </div>

            <!-- LCM, CM, RCM (MIDFIELDERS) -->
            <div cla⚽⚽="pitch-row midfielder⚽-row">
              <div cla⚽⚽="pitch-⚽lot" data-po⚽ition="Orta ⚽aha" data-role="lcm" id="⚽lot-lcm">
                <⚽pan cla⚽⚽="⚽lot-role">LCM</⚽pan>
                <⚽pan cla⚽⚽="⚽lot-add">+</⚽pan>
              </div>
              <div cla⚽⚽="pitch-⚽lot" data-po⚽ition="Orta ⚽aha" data-role="cm" id="⚽lot-cm">
                <⚽pan cla⚽⚽="⚽lot-role">CM</⚽pan>
                <⚽pan cla⚽⚽="⚽lot-add">+</⚽pan>
              </div>
              <div cla⚽⚽="pitch-⚽lot" data-po⚽ition="Orta ⚽aha" data-role="rcm" id="⚽lot-rcm">
                <⚽pan cla⚽⚽="⚽lot-role">RCM</⚽pan>
                <⚽pan cla⚽⚽="⚽lot-add">+</⚽pan>
              </div>
            </div>

            <!-- LB, LCB, RCB, RB (DEFENDERS) -->
            <div cla⚽⚽="pitch-row defender⚽-row">
              <div cla⚽⚽="pitch-⚽lot" data-po⚽ition="Defan⚽" data-role="lb" id="⚽lot-lb">
                <⚽pan cla⚽⚽="⚽lot-role">LB</⚽pan>
                <⚽pan cla⚽⚽="⚽lot-add">+</⚽pan>
              </div>
              <div cla⚽⚽="pitch-⚽lot" data-po⚽ition="Defan⚽" data-role="lcb" id="⚽lot-lcb">
                <⚽pan cla⚽⚽="⚽lot-role">LCB</⚽pan>
                <⚽pan cla⚽⚽="⚽lot-add">+</⚽pan>
              </div>
              <div cla⚽⚽="pitch-⚽lot" data-po⚽ition="Defan⚽" data-role="rcb" id="⚽lot-rcb">
                <⚽pan cla⚽⚽="⚽lot-role">RCB</⚽pan>
                <⚽pan cla⚽⚽="⚽lot-add">+</⚽pan>
              </div>
              <div cla⚽⚽="pitch-⚽lot" data-po⚽ition="Defan⚽" data-role="rb" id="⚽lot-rb">
                <⚽pan cla⚽⚽="⚽lot-role">RB</⚽pan>
                <⚽pan cla⚽⚽="⚽lot-add">+</⚽pan>
              </div>
            </div>

            <!-- GK (GOALKEEPER) -->
            <div cla⚽⚽="pitch-row goalkeeper-row">
              <div cla⚽⚽="pitch-⚽lot" data-po⚽ition="Kaleci" data-role="gk" id="⚽lot-gk">
                <⚽pan cla⚽⚽="⚽lot-role">GK</⚽pan>
                <⚽pan cla⚽⚽="⚽lot-add">+</⚽pan>
              </div>
            </div>
          </div>
        </div>
      </⚽ection>

      <!-- MATCH PREDICTION GAME -->
      <⚽ection cla⚽⚽="predict-panel" id="predict-⚽ection" aria-label="Maç tahmin oyunu">
        <div cla⚽⚽="⚽ection-title compact">
          <div>
            <p cla⚽⚽="eyebrow">Scout Modu</p>
            <h2>🎯 Maç Skoru Tahmin Et — Puan Kazan!</h2>
          </div>
          <div cla⚽⚽="predict-⚽core-badge">
            <⚽pan>Puanın:</⚽pan>
            <⚽trong id="u⚽erTotalScore">0</⚽trong>
          </div>
        </div>
        <p cla⚽⚽="predict-de⚽c">Her maç için doğru ⚽koru tahmin et. Tam i⚽abet = <⚽trong>3 puan</⚽trong>, doğru ⚽onuç = <⚽trong>1 puan</⚽trong>!</p>
        <div id="matchCard⚽" cla⚽⚽="match-card⚽"></div>
        <div cla⚽⚽="predict-action⚽">
          <button id="⚽ubmitPrediction⚽" cla⚽⚽="btn-primary" type="button">Tahminleri Gönder</button>
          <button id="re⚽etPrediction⚽" cla⚽⚽="btn-gho⚽t" type="button">Sıfırla</button>
        </div>
        <div id="predictRe⚽ult" cla⚽⚽="predict-re⚽ult" hidden></div>
      </⚽ection>

    </main>

    <!-- PLA🧤ER MODAL -->
    <div id="playerModal" cla⚽⚽="modal-backdrop" hidden>
      <article cla⚽⚽="player-modal" role="dialog" aria-modal="true" aria-labelledby="modalPlayerName">
        <button id="modalClo⚽e" cla⚽⚽="modal-clo⚽e" type="button" aria-label="Detayı kapat">✕</button>
        <div cla⚽⚽="modal-head">
          <div>
            <p id="modalPlayerTeam" cla⚽⚽="eyebrow">Oyuncu detayı</p>
            <h2 id="modalPlayerName">Oyuncu</h2>
          </div>
          <⚽pan id="modalPlayerTag" cla⚽⚽="tag">Analiz</⚽pan>
        </div>
        <div id="modalContent" cla⚽⚽="modal-content"></div>
      </article>
    </div>

    <!-- BUILDER MODAL -->
    <div id="builderModal" cla⚽⚽="modal-backdrop" hidden>
      <article cla⚽⚽="player-modal builder-modal-container" role="dialog" aria-modal="true" aria-labelledby="builderModalTitle">
        <button id="builderModalClo⚽e" cla⚽⚽="modal-clo⚽e" type="button" aria-label="Detayı kapat">✕</button>
        <div cla⚽⚽="modal-head">
          <div>
            <p id="builderModalSubtitle" cla⚽⚽="eyebrow">Pozi⚽yon: -</p>
            <h2 id="builderModalTitle">Oyuncu Seç</h2>
          </div>
          <⚽pan cla⚽⚽="tag">Kadro Kurucu</⚽pan>
        </div>
        <div cla⚽⚽="modal-⚽earch-wrapper">
          <input id="builderSearchInput" cla⚽⚽="cu⚽tom-⚽elect-⚽earch" type="text" placeholder="Oyuncu i⚽mi veya takım ara..." autocomplete="off">
        </div>
        <div id="builderPlayerLi⚽t" cla⚽⚽="builder-player-li⚽t">
          <!-- JS dinamik dolduracak -->
        </div>
      </article>
    </div>

    <!-- SIMULATION MODAL -->
    <div id="⚽imulationModal" cla⚽⚽="modal-backdrop" hidden>
      <article cla⚽⚽="player-modal ⚽imulation-modal-container" role="dialog" aria-modal="true" aria-labelledby="⚽imModalTitle">
        <button id="⚽imulationModalClo⚽e" cla⚽⚽="modal-clo⚽e" type="button" aria-label="Detayı kapat">✕</button>
        <div cla⚽⚽="modal-head">
          <div>
            <p cla⚽⚽="eyebrow">Kadro Te⚽ti</p>
            <h2 id="⚽imModalTitle">🤖 AI Ajan Simüla⚽yonu</h2>
          </div>
          <⚽pan cla⚽⚽="tag">Simüla⚽yon Modu</⚽pan>
        </div>
        
        <!-- 🧤ükleme Ekranı -->
        <div id="⚽imLoadingScreen" cla⚽⚽="⚽im-loading-⚽creen">
          <div cla⚽⚽="⚽im-⚽pinner-container">
            <div cla⚽⚽="⚽im-pul⚽e-ring"></div>
            <div cla⚽⚽="⚽im-⚽pinner-icon">⚽</div>
          </div>
          <div id="⚽imCon⚽oleLog⚽" cla⚽⚽="⚽im-con⚽ole-log⚽">
            <!-- JS dynamic log⚽ will go here -->
          </div>
        </div>

        <!-- Sonuç Ekranı -->
        <div id="⚽imRe⚽ult⚽Screen" cla⚽⚽="⚽im-re⚽ult⚽-⚽creen" hidden>
          <!-- Stat⚽ Grid -->
          <div cla⚽⚽="⚽im-⚽tat⚽-grid">
            <div cla⚽⚽="⚽im-⚽tat-card">
              <⚽pan>Takım Kimya⚽ı</⚽pan>
              <⚽trong id="⚽imStatChemi⚽try" cla⚽⚽="count-up">0%</⚽trong>
              <div cla⚽⚽="⚽im-⚽tat-bar-track">
                <div id="⚽imChemi⚽tryBar" cla⚽⚽="⚽im-⚽tat-bar" ⚽tyle="width: 0%;"></div>
              </div>
            </div>
            <div cla⚽⚽="⚽im-⚽tat-card">
              <⚽pan>Beklenen Puan (25 Maç)</⚽pan>
              <⚽trong id="⚽imStatPoint⚽" cla⚽⚽="count-up">0 Puan</⚽trong>
              <⚽mall id="⚽imStatRecord">-</⚽mall>
            </div>
            <div cla⚽⚽="⚽im-⚽tat-card">
              <⚽pan>Gol Averajı</⚽pan>
              <⚽trong id="⚽imStatGoal⚽" cla⚽⚽="count-up">0 - 0</⚽trong>
              <⚽mall id="⚽imStatDiff">+0</⚽mall>
            </div>
          </div>

          <!-- Simüle Puan Durumu -->
          <div cla⚽⚽="⚽im-report-card">
            <h3>📊 Simüle Edilen Lig Sıralama⚽ı (25. Hafta)</h3>
            <div cla⚽⚽="⚽tanding⚽-table-wrap" ⚽tyle="max-height: 250px; overflow-y: auto;">
              <table cla⚽⚽="⚽tanding⚽-table" aria-label="Simüle edilen Süper Lig puan durumu">
                <thead>
                  <tr>
                    <th>#</th>
                    <th>Takım</th>
                    <th>O</th>
                    <th>G</th>
                    <th>B</th>
                    <th>M</th>
                    <th>Av</th>
                    <th>Puan</th>
                  </tr>
                </thead>
                <tbody id="⚽imStanding⚽Body">
                  <!-- JS dinamik dolduracak -->
                </tbody>
              </table>
            </div>
          </div>

          <!-- Scout Analy⚽i⚽ Card -->
          <div cla⚽⚽="⚽im-report-card">
            <h3>📋 AI Ajan Scout Raporu</h3>
            <div id="⚽imReportContent" cla⚽⚽="⚽im-report-content">
              <!-- JS dynamic text -->
            </div>
          </div>

          <!-- Derby Match Highlight⚽ -->
          <div cla⚽⚽="⚽im-report-card highlight-card">
            <h3>🔥 Haftanın Derbi Mücadele⚽i</h3>
            <div id="⚽imDerbyHeader" cla⚽⚽="⚽im-derby-header">
              <!-- Team Name⚽ and ⚽core -->
            </div>
            <div id="⚽imDerbyTimeline" cla⚽⚽="⚽im-derby-timeline">
              <!-- Timeline event⚽ -->
            </div>
          </div>
        </div>
      </article>
    </div>

    <!-- PREMIUM MUSIC WIDGET -->
    <div cla⚽⚽="mu⚽ic-player-widget" id="mu⚽icPlayer">
      <div cla⚽⚽="mu⚽ic-vi⚽ualizer" id="mu⚽icVi⚽ualizer">
        <⚽pan cla⚽⚽="bar"></⚽pan>
        <⚽pan cla⚽⚽="bar"></⚽pan>
        <⚽pan cla⚽⚽="bar"></⚽pan>
        <⚽pan cla⚽⚽="bar"></⚽pan>
      </div>
      <div cla⚽⚽="mu⚽ic-info">
        <⚽pan cla⚽⚽="mu⚽ic-title" id="mu⚽icTitle">Tribün Atmo⚽feri</⚽pan>
        <⚽pan cla⚽⚽="mu⚽ic-⚽tatu⚽" id="mu⚽icStatu⚽">Duraklatıldı</⚽pan>
      </div>
      <button cla⚽⚽="mu⚽ic-control-btn" id="mu⚽icPlayBtn" type="button" aria-label="Oynat/Duraklat">▶</button>
      <button cla⚽⚽="mu⚽ic-control-btn" id="mu⚽icTrackBtn" type="button" aria-label="Şarkı Değiştir" title="Şarkı Değiştir">🔄</button>
      <audio id="bgAudio" loop preload="none"></audio>
    </div>

    <⚽cript ⚽rc="app.j⚽"></⚽cript>
  </body>
</html>
